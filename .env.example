# Required. Generate with:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
SECRETS_KEY=

# Default-off signup. Set true briefly to create users, then turn it off again.
REGISTRATION_ENABLED=false

# Local HTTP only. Use true behind HTTPS.
SESSION_COOKIE_SECURE=false

# Optional provider keys. Fill only the sources you use.
EVM_PORTFOLIO_PROVIDER=zerion
DEBANK_ACCESS_KEY=
ONEINCH_API_KEY=
ZERION_API_KEY=
COINSTATS_API_KEY=
COINMARKETCAP_API_KEY=

# Optional.
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173
ENABLE_API_DOCS=0
